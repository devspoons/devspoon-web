# =============================================================================
# nginx_uwsgi 스택 환경변수 (template)
# - 운영 시 본 파일을 .env 로 복사 후 CHANGE_ME_* 값을 실제 자격증명으로 교체
# - .env 는 .gitignore 에 의해 git 추적 대상에서 제외됨 (이 파일만 추적)
# =============================================================================

# ── Project ─────────────────────────────────────────────────────────────────
PROJECT_DIR=django_sample
WORKERS=4
GUNICORN_PORT=8000
REQUIREMENTS=./requirements.txt
PROJECT_NAME=django_sample

# ── Logging (docker compose log driver) ────────────────────────────────────
# compose 측 ${VAR:-default} 와 이중 안전. .env 키 누락 시에도 빈 문자열 미전달.
LOG_DRIVER=json-file
LOG_OPT_MAXF=5
LOG_OPT_MAXS=100m

# ── Redis / Celery 자격증명 (SSOT) ─────────────────────────────────────────
# REDIS_PASSWORD 한 값으로 redis / celery / celery-beat / flower 가 모두 동기화된다.
#  - compose 의 redis 컨테이너 command 에 --requirepass 로 주입
#  - celery / celery-beat / flower 의 CELERY_BROKER_URL 은 compose 에서
#    redis://:${REDIS_PASSWORD}@redis:6379/3 형태로 합성되어 .env 에 따로 두지 않음
#    → 두 값 drift 가 구조적으로 불가능 (한 곳만 갱신).
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Flower Basic Auth ──────────────────────────────────────────────────────
# flower 컨테이너는 5555/tcp 를 외부에 노출하므로 반드시 강한 자격증명으로 교체할 것.
FLOWER_ID=CHANGE_ME_FLOWER_USER
FLOWER_PWD=CHANGE_ME_FLOWER_PASSWORD

# ── ulimits (현재 비활성, 변수만 정의) ──────────────────────────────────────
# nginx.conf 의 `worker_rlimit_nofile 65535` 와 호환되는 호스트측 ulimits 값.
# compose 의 webserver 서비스에 ulimits 블록을 두었으나 의도적으로 주석 처리해
# 실제로는 docker daemon 기본값(LimitNOFILE, 통상 1048576)을 사용한다.
# 호스트 OS (RHEL/podman 등) 에서 기본값이 다른 경우에만 compose 의 주석을 풀어 활성.
ULIMIT_NOFILE_SOFT=65535
ULIMIT_NOFILE_HARD=65535
