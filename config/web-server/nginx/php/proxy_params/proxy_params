# =====================================================================
# 프록시 공통 파라미터 — proxy_pass 를 사용하는 location 블록 "안에서" include 한다.
#   사용 예) location / {
#                ...
#                proxy_pass http://app_backend;
#                include /etc/nginx/proxy_params;
#            }
# 주의:
#  - http 컨텍스트에서 전역 include 하지 않는다(정적 파일 location 등에 불필요/부작용).
#  - location 에 자체 proxy_set_header 가 따로 있으면 그 location 은 상위 레벨의 proxy_set_header 를
#    "전혀" 상속하지 않는다. 같은 헤더를 양쪽에 중복 정의하면 헤더가 2번 전송되니 주의.
#  - 이 파일은 docker-compose 에서 단일 파일로 마운트된다:
#       config/web-server/nginx/<stack>/proxy_params/proxy_params : /etc/nginx/proxy_params
#    그러므로 nginx.conf 에서는 `include /etc/nginx/proxy_params/*;`(디렉터리 글로브) 가 아니라
#    각 location 의 `include /etc/nginx/proxy_params;`(파일) 로 로드한다.
# =====================================================================

# --- 백엔드로 전달하는 클라이언트 정보 헤더 ---
proxy_set_header Host              $host;                       # 원본 호스트명 (VirtualHost 라우팅용; $http_host 와 달리 정규화/포트 제거)
proxy_set_header X-Real-IP         $remote_addr;                # 클라이언트 실제 IP
proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;  # 프록시 체인 IP 목록 (client, proxy1, ...)
proxy_set_header X-Forwarded-Proto $scheme;                     # 원본 프로토콜 (http/https) — 백엔드 리다이렉트/secure 쿠키 판단용
proxy_set_header X-Forwarded-Host  $host;                       # 원본 호스트 (체인 보존)
proxy_set_header X-Forwarded-Port  $server_port;                # 클라이언트가 접속한 포트

# --- HTTP/1.1 프록시 기본값 (백엔드 커넥션 처리) ---
# 도메인 conf 는 proxy_pass 로 컨테이너:포트를 직접 가리키므로 upstream keepalive 커넥션 풀은 사용하지 않는다
# (요청마다 백엔드 커넥션을 새로 맺음). 아래 두 줄은 HTTP/1.1 통신 + hop-by-hop Connection 헤더 비우기의
# 표준 기본값이다. (추후 upstream{} + `keepalive N;` 을 다시 도입하면 그대로 풀링에 재사용된다.)
# (과거 설정의  proxy_set_header Connection "Upgrade"; / proxy_set_header Connection keep-alive;  두 줄은
#   ① 같은 헤더를 두 번 set 하여 Connection 헤더가 2개 전송되는 버그였고
#   ② WebSocket(현재 미사용) 전용 패턴이라 일반 프록시에 부적절하므로 제거함.
#  WebSocket 을 다시 쓰려면 nginx.conf 에 map $http_upgrade $connection_upgrade 를 정의하고
#  해당 location 에서만 proxy_set_header Upgrade $http_upgrade; proxy_set_header Connection $connection_upgrade; 로 덮어쓸 것.)
proxy_http_version 1.1;
proxy_set_header   Connection "";

# --- 리다이렉트 ---
proxy_redirect off;   # 백엔드의 Location/Refresh 응답 헤더를 재작성하지 않고 그대로 전달

# --- 타임아웃 (백엔드 무한 대기 방지; 앱 서버 timeout 과 동일 또는 짧게 맞출 것) ---
proxy_connect_timeout 60s;
proxy_send_timeout    60s;
proxy_read_timeout    60s;

# --- 응답/요청 버퍼링 ---
# ⚠ buffering 을 off 로 두면 느린 클라이언트가 응답을 다 받을 때까지 백엔드 워커가 점유되어(slow-read)
#    백엔드가 그대로 노출/고갈된다. 과거 설정의 `proxy_buffering off;` 는 이 이유로 on 으로 교정함.
proxy_buffering          on;     # 백엔드 응답을 nginx 버퍼로 받아 백엔드를 빨리 놓아준다
proxy_request_buffering  on;     # 클라이언트 요청 본문도 버퍼링 후 백엔드 전달 (slow-write 방어)
proxy_buffer_size        4k;     # 응답 헤더용 버퍼
proxy_buffers            8 4k;   # 응답 본문용 버퍼 (8 × 4KB = 32KB) — 일반 JSON/HTML API 응답에 적합
proxy_busy_buffers_size  8k;     # 클라이언트로 전송 중인 버퍼 상한 (= proxy_buffer_size × 2)
proxy_max_temp_file_size 1024m;  # 버퍼 초과분의 디스크 임시 저장 한도 (대용량 응답 대비; 0 이면 임시파일 미사용)
