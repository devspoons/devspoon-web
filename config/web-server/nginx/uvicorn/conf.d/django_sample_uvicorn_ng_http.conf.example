# ===============================================
# Production-grade nginx server block — Django/Uvicorn (HTTP)
# 도메인:   localhost (로컬 검증/스모크 테스트용)
# 백엔드:   uvicorn-app:8000
# 웹루트:   /www/django_sample
# ※ 본 파일은 sample_nginx_http.conf 의 placeholder 치환 결과와 동등한 보안/성능 베이스라인을 따름.
# ===============================================

upstream django_sample_backend {
    server uvicorn-app:8000;
    keepalive 16;
}

server {
    listen       80;
    server_name  localhost www.localhost;

    # 악성 봇/스캐너 차단 (nginx-ultimate-bad-bot-blocker, /etc/nginx/bots.d/ 로 cron 자동 갱신)
    include /etc/nginx/bots.d/blockbots.conf;
    include /etc/nginx/bots.d/ddos.conf;
    add_header Content-Security-Policy "frame-ancestors 'self';" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    client_max_body_size 50M;
    open_file_cache max=1000 inactive=20s;
    open_file_cache_valid 30s;
    open_file_cache_min_uses 2;
    open_file_cache_errors on;

    access_log /log/nginx/django_sample.uvicorn_access_http.log main buffer=32k flush=5s;
    error_log  /log/nginx/django_sample.uvicorn_error_http.log warn;

    location /media {
        autoindex off;
        alias /www/django_sample/media;
        gzip_static on;
        expires max;
        add_header Cache-Control "public, max-age=31536000, immutable";
        location ~* \.(jpg|jpeg|png|gif|webp|svg|ico)$ {
            expires max;
            add_header Cache-Control "public, max-age=31536000, immutable";
            access_log off;
        }
        access_log off;
    }
    location /static {
        autoindex off;
        alias /www/django_sample/static;
        gzip_static on;
        expires max;
        add_header Cache-Control "public, max-age=31536000, immutable";
        location ~* \.(css|js)$ {
            expires max;
            add_header Cache-Control "public, max-age=31536000, immutable";
            access_log off;
        }
        location ~* \.(woff|woff2|ttf|eot)$ {
            expires max;
            add_header Cache-Control "public, max-age=31536000, immutable";
            add_header Access-Control-Allow-Origin "*";
            access_log off;
        }
        access_log off;
    }

    location / {
        autoindex off;
        #limit_req  zone=general burst=20 nodelay;
        #limit_conn addr 10;
        #limit_except GET POST HEAD OPTIONS PUT DELETE { deny all; }

        proxy_pass http://uvicorn-app:8000;
        include /etc/nginx/proxy_params;
    }

    location ^~ /.well-known/acme-challenge/ {
        allow all;
        root /www/certbot;   # 고정 ACME 챌린지 루트 (letsencrypt.sh -w 와 동일; 앱 루트로 치환되면 안 됨)
        try_files $uri =404;
    }

    location ~ /\. {
        deny all; access_log off; log_not_found off;
    }
    location ~* \.(log|binary|pem|enc|crt|conf|cnf|sql|sh|key|yml|yaml|toml|ini|env|lock|bak|backup|swp)$ {
        deny all; access_log off; log_not_found off;
    }
    location ~* (composer\.(json|lock|phar)|package(-lock)?\.json|yarn\.lock|requirements\.txt|Pipfile(\.lock)?|pyproject\.toml|contributing\.md|license\.txt|readme\.(rst|md|txt)|copyright|artisan|gulpfile\.js|phpunit\.xml|access_log|error_log|gruntfile\.js)$ {
        deny all; access_log off; log_not_found off;
    }
    location = /favicon.ico { log_not_found off; access_log off; }
    location = /robots.txt  { log_not_found off; access_log off; allow all; }
}
