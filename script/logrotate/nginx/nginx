# Nginx 로그 로테이션 설정
# - Docker 컨테이너 환경에서 USR1 signal 방식 사용 (nginx 권장 패턴)
# - postrotate 에서 PID 파일을 읽어 master 에게 USR1 → 워커가 새 fd 로 로그 재오픈
# - su root root: 호스트 마운트(예: WSL /mnt/c) 가 parent 디렉토리를 0777 로 노출하는
#   경우, logrotate 가 "insecure permissions" 로 회전을 거부한다. 컨테이너 안에서 root 로
#   회전하도록 명시 (`man logrotate` 의 su 디렉티브 — parent dir 권한 검사 우회).
/log/nginx/*.log {
    su root root
    daily
    size 100M
    rotate 30
    missingok
    notifempty
    compress
    delaycompress
    create 0640 nginx nginx
    sharedscripts
    postrotate
        # Nginx 마스터 프로세스에 USR1 전송 — 로그 파일 재오픈
        if [ -f /var/run/nginx.pid ]; then
            kill -USR1 `cat /var/run/nginx.pid`
        fi
    endscript
}
